       await fetch(`/api/maps/${map.id}/pins/${pinId}`, { method: 'DELETE' });
       map.pins = map.pins.filter(p => p.id !== pinId);
       // ... rest stays the same
     }


  8. Image upload — swap base64 for a real URL:

     async function onImageUpload(e) {
       const file = e.target.files[0]; if (!file) return;
       const form = new FormData();
       form.append('image', file);

       // Option A: upload via your server
       const res    = await fetch(`/api/maps/${getActiveMap().id}/image`, { method: 'POST', body: form });
