  1. On page load — replace the MAPS[] array with fetched data:

     async function loadMaps() {
       const res  = await fetch('/api/maps');
       MAPS       = await res.json();   // server returns [{id, name, imageUrl, width, height, pins:[...]}]
       renderAdminLibrary();
       renderAdminCanvas();
       if (MAPS.length) adminSelectMap(MAPS[0].id);
       renderUserMapTabs();
     }
     loadMaps();


  2. adminCreateMap() — POST to create:

     async function adminCreateMap() {
       const res = await fetch('/api/maps', {
         method: 'POST',
         headers: { 'Content-Type': 'application/json' },
         body: JSON.stringify({ name: 'Unnamed Map', width: 900, height: 600 }),
       });
       const newMap = await res.json();  // { id, name, imageUrl, width, height, pins: [] }
       MAPS.push(newMap);
       adminSelectMap(newMap.id);
       renderAdminLibrary();
     }


  3. adminDeleteMap(id) — DELETE:

     async function adminDeleteMap(id) {
       if (!confirm('Delete this map?')) return;
       await fetch(`/api/maps/${id}`, { method: 'DELETE' });
       MAPS = MAPS.filter(m => m.id !== id);
       // ... rest of the function stays the same
     }


  4. adminSaveMap() — PUT map-level fields:

     async function adminSaveMap() {
       const map = getActiveMap(); if (!map) return;
       await fetch(`/api/maps/${map.id}`, {
         method: 'PUT',
         headers: { 'Content-Type': 'application/json' },
         body: JSON.stringify({
           name:     map.name,
           imageUrl: map.imageDataUrl,   // send the CDN URL, not base64
           width:    map.width,
           height:   map.height,
         }),
       });
       showToast('Map saved!');
     }


  5. onCanvasClick() — POST new pin after adding it to the local array:

     // After map.pins.push(pin):
     const res = await fetch(`/api/maps/${map.id}/pins`, {
       method: 'POST',
       headers: { 'Content-Type': 'application/json' },
       body: JSON.stringify(pin),
     });
     const saved = await res.json();
     pin.id = saved.id;  // use the server-assigned ID


  6. updatePin() — debounce + PUT on change:

     // Wrap with a debounce (300ms) so it doesn't fire on every keystroke:
     const debouncedPinSave = debounce(async (mapId, pin) => {
       await fetch(`/api/maps/${mapId}/pins/${pin.id}`, {
         method: 'PUT',
         headers: { 'Content-Type': 'application/json' },
         body: JSON.stringify(pin),
       });
     }, 300);

     function updatePin(pinId, key, val) {
       const map = getActiveMap(); if (!map) return;
       const pin = getPin(map, pinId); if (!pin) return;
       pin[key] = val;
       renderAdminPins();
       debouncedPinSave(map.id, pin);
     }


  7. adminDeletePin() — DELETE:

     async function adminDeletePin(pinId) {
